<section class="cta-section">
  <div class="cta-bg"></div>
  <div class="container cta-content">
    <h2 class="cta-title">Pronto para ter uma presença marcante por onde passar?</h2>
    <a href="https://wa.me/5567991043906" target="_blank" rel="noopener noreferrer" class="btn-agendar-lg">QUERO AGENDAR MEU MOMENTO</a>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    padding: 120px 0;
    text-align: center;
    overflow: hidden;
    background-color: var(--color-marian-blue);
  }

  .cta-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('https://images.unsplash.com/photo-1505330622279-bf7d7fc918f4?q=80&w=2070&auto=format&fit=crop');
    background-size: cover;
    background-position: center;
    opacity: 0.1;
    z-index: 0;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 48px;
    color: var(--text-on-surface);
  }

  .btn-agendar-lg {
    display: inline-block;
    background-color: var(--color-antique-gold);
    color: var(--text-on-gold);
    padding: 20px 48px;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 4px;
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  .btn-agendar-lg:hover {
    filter: brightness(1.1);
    transform: translateY(-3px);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.4);
    border-color: #050A10;
  }
</style>
